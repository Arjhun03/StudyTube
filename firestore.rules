rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userRole() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function hasOnlyUserManagedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['displayName', 'photoURL', 'emailVerified', 'providerIds', 'lastLoginAt', 'updatedAt']);
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role in ['student', 'admin']
        && request.resource.data.role == 'student';
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && hasOnlyUserManagedFields()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());

      match /quizzes/{quizId} {
        allow read, write: if isAuthenticated()
          && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid || isAdmin());
      }

      match /flashcards/{cardId} {
        allow read, write: if isAuthenticated()
          && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid || isAdmin());
      }

      match /chats/{chatId} {
        allow read, write: if isAuthenticated()
          && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
